{
  "name": "ai-farming-cultivation-estimator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:client",
    "dev:client": "vite",
    "dev:server": "tsx server.ts",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@google/genai": "^1.29.1",
    "@prisma/client": "^6.2.1",
    "@types/express": "^5.0.6",
    "cors": "^2.8.5",
    "d3": "^7.9.0",
    "dotenv": "^16.4.7",
    "esbuild": "^0.28.0",
    "express": "^5.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsx": "^4.22.3",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/d3": "^7.4.3",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^8.2.2",
    "prisma": "^6.2.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
